prepCNVImport <-  function(target_files, Array_Type) {
targetDirectory <- dirname(target_files$Basename[1])
sample_sheet <- data.frame(matrix(0, 3 , length(target_files$Basename)))
names(sample_sheet) <- c("Sample_Name", "Sentrix_ID", "Sentrix_Position")
for (i in 1:length(target_files$Basename)) {
sample_sheet$Sample_Name[i] <- basename(target_files$Basename[i])
Sentrix_parts <- strsplit(sample_sheet$Sample_Name[i], "_")[[1]]
sample_sheet$Sentrix_ID[i] <- Sentrix_parts[1]
sample_sheet$Sentrix_Position[i] <- Sentrix_parts[2]
}
return(list("array_type" = Array_Type, "directory" = targetDirectory, "sample_sheet" = sample_sheet))
}
