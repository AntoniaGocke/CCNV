seg <- cum.CNV(SPSE_A, segmentationMode = "all", detail.regions = detail_regions, output = "all", conumee.version = 2)
write.csv(seg$multiseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/SPSE_A_multiseg.csv")
write.csv(seg$singleseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/SPSE_A_singleseg.csv")
