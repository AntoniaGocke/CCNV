#Laden der Datei (Excel, CSV...) mit Spalten: Gene, p.value, difference
vp <- read.csv("/Volumes/PhD/AGSchluﮊter/AG_Lange/240522_PaCa5061_hs_T-Test.txt",sep = "\t, dec = ",)
#Laden der Datei (Excel, CSV...) mit Spalten: Gene, p.value, difference
vp <- read.csv("/Volumes/PhD/AGSchluﮊter/AG_Lange/240522_PaCa5061_hs_T-Test.txt",sep = "\t", dec = ",")
foldchange=log(2, base = 2)
#Einteilung in Gruppen basierend auf Signifikanz von p.value und difference. Die Thresholds kﺣﭘnnen an dieser Stelle ebenfalls angepasst werden (Voreinstellung 1 -> 2-fold change)
vp$diffexpressed <- "NO"
#if pvalue < 0.05, set as "p-value"
vp$diffexpressed[vp$p.value < 0.05] <- "p-value"
#if qvalue < 0.05, set as "q-value"
vp$diffexpressed[vp$p.value < 0.05] <- "q-value"
vp$diffexpressed[vp$difference > foldchange & vp$p.value < 0.05] <- "UP1.5"
# if log2Foldchange < -0.58 and pvalue < 0.05, set as "DOWN"
vp$diffexpressed[vp$difference < -(foldchange) & vp$p.value < 0.05] <- "DOWN1.5"
# if log2Foldchange > 0.58 and pvalue < 0.05, set as "UP"
vp$diffexpressed[vp$difference > (foldchange) & vp$q.value < 0.05 & vp$p.value < 0.05] <- "qvalueUP"
# if log2Foldchange < -0.58 and pvalue < 0.05, set as "DOWN"
vp$diffexpressed[vp$difference < -(foldchange) & vp$q.value < 0.05 & vp$p.value < 0.05] <- "qvalueDOWN"
#Hier kﺣﭘnnen die Farben der jeweilgen Gruppe verﺣ۳ndert werden. Die Reihenfolge der Farben entspricht der Reihenfolge der "names"
mycolors <- c("lightblue", "mistyrose", "blue", "red", "grey", "black", "black")
names(mycolors) <- c("DOWN1.5", "UP1.5","qvalueDOWN", "qvalueUP", "NO", "p-value", "q-value" )
#Erstellung iener weitern Spalte in "vp" zur Beschriftung der signifikanten Datenpunkte
vp$delabel <- NA
vp$delabel[vp$diffexpressed != "NO" & vp$diffexpressed != "UP1.5"& vp$diffexpressed != "DOWN1.5"& vp$diffexpressed != "q-value"] <- vp$Gene[vp$diffexpressed != "NO" & vp$diffexpressed != "UP1.5"& vp$diffexpressed != "DOWN1.5"& vp$diffexpressed != "q-value"]
#Erstellung des Volcano Plots
#defienieren der overlaps bzw Anzahl angezeigter Labels (5 moderat, 10 viele labels)
options(ggrepel.max.overlaps = 10)
p <- ggplot(data=vp, aes(x=difference, y=-log10(p.value), col=diffexpressed, label=delabel)) +
#change geom_point size to change the size of the data points
geom_point(size=2) +
theme_minimal() +
#change geom_text_repel size to change font size of the data point labels (Note: this can change the amount of displayed labels)
geom_text_repel(size=3) +
#Voreinstellung fﺣﺙr die Hilfslinien im Volcano Plot. Sollten bei Verﺣ۳nderung der fold changes mit angepasst werden
geom_vline(xintercept=c(-(foldchange), foldchange), col="grey", linetype = "dashed", linewidth = 1) +
geom_hline(yintercept=-log10(0.05), col="grey", linetype = "dashed", linewidth = 1) +
geom_vline(xintercept=c(0, 0), col="grey", linetype = "solid") +
scale_colour_manual(values = mycolors) +
#Verﺣ۳ndern der Achsenbezeichnung
labs(x="fold change [Log2]", y="p-value [-Log10]", col="Description") +
#Entfernen der Legende (Kann auch entfernt werden und wird dann mit angezeigt)
theme(legend.position = "none") +
#Hinzufﺣﺙgen eines Titels
ggtitle("")+
theme(plot.title = element_text(hjust = 0.5)) +
#Hinzufﺣﺙgen von X und Y-Achse und Entfernung des Gitternetzes
#theme(axis.line = element_line(colour = "black", size = 2, linetype = "solid")) +
theme(axis.ticks = element_line(linewidth = 1.5, color="black"))+
theme(axis.ticks.length = unit(0.3, "cm"))+
theme(panel.grid.major = element_blank(), panel.grid.minor = element_blank())+
theme(axis.text = element_text(size = 22, face = 2, color="black"))+
theme(axis.title = element_text(size = 22, face = 2))+
scale_x_continuous(limits = c(-3, 3))+
#scale_y_continuous(limits = c(0, 5))+
theme(axis.title.y = element_text(vjust = +2))+
theme(axis.title.x = element_text(vjust = -0))+
theme(panel.border = element_rect(colour = "black", fill=NA, linewidth =3))
print(p)
