knitr::opts_chunk$set(echo = TRUE)
target_files <- read.csv("/Volumes/PhD/Ependymoma/Ependymoma_methylation_mainCohort/sample_info_02_08_2022_850_Mac.csv", header=TRUE, sep=";")
#
g_files <- paste0(target_files$Basename, "_Grn.idat")
r_files <- paste0(target_files$Basename,"_Red.idat" )
# test if every file is an idat file
test_grn <- sapply(g_files, readChar, nchars = 4)
test_red <- sapply(r_files, readChar, nchars = 4)
#This will give out file names if they are not IDAT and character 0 if all files are IDAT
test_grn[test_grn != "IDAT"]
## named character(0)
test_red[test_red != "IDAT"]
## named character(0)
#remove duplicates
while (anyDuplicated(target_files$Basename) != "0") {
target_files <- target_files[-anyDuplicated(target_files$Basename),]
}
details <- read.csv("/Volumes/PhD/Ependymoma/Ependymoma_methylation_mainCohort/detail_conumee.csv")
detail_regions <- details$name
setwd("~/Documents/GitHub/CCNV/R")
devtools::load_all()
SPSE_A <- target_files[which(target_files$Classifier_new_version %in% c("EPN_SPINE_SE_A", "EPN_SPINE_SE")),]
seg <- cum.CNV(SPSE_A, segmentationMode = "all", detail.regions = detail_regions, output = "all", conumee.version = 2)
write.csv(seg$multiseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/SPSE_A_multiseg.csv")
write.csv(seg$singleseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/SPSE_A_singleseg.csv")
devtools::load_all()
MPE <- target_files[which(target_files$Classifier_new_version_condensed == "EPN_MPE"),]
MPE_A <- MPE[which(MPE$Schüllers_subgroup_19.08.21 == "A"),]
seg <- cum.CNV(MPE_A, segmentationMode = "all", detail.regions = detail_regions, output = "all", conumee.version = 2)
write.csv(seg$multiseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/MPE_A_multiseg.csv")
write.csv(seg$singleseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/MPE_A_singleseg.csv")
MPE <- target_files[which(target_files$Classifier_new_version_condensed == "EPN_MPE"),]
MPE_B <- MPE[which(MPE$Schüllers_subgroup_19.08.21 == "B"),]
seg <- cum.CNV(MPE_B, segmentationMode = "all", detail.regions = detail_regions, output = "all", conumee.version = 2)
write.csv(seg$multiseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/MPE_B_multiseg.csv")
write.csv(seg$singleseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/MPE_B_singleseg.csv")
SPN <- target_files[which(target_files$Classifier_new_version_condensed == "EPN_SPINE"),]
seg <- cum.CNV(SPN, segmentationMode = "all", detail.regions = detail_regions, output = "all", conumee.version = 2)
write.csv(seg$multiseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/SPINE_multiseg.csv")
write.csv(seg$singleseg, "/Volumes/PhD/Ependymoma/CumulativePlotsEPN_Shweta/SPINE_singleseg.csv")
